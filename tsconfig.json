{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@optcg/engine": ["./packages/engine/src/index.ts"],
      "@optcg/engine/*": ["./packages/engine/src/*"],
      "@optcg/cards": ["./packages/cards/src/index.ts"],
      "@optcg/cards/*": ["./packages/cards/src/*"],
      "@optcg/shared-types": ["./packages/shared-types/src/index.ts"],
      "@optcg/shared-types/*": ["./packages/shared-types/src/*"]
    }
  },
  "files": []
}
